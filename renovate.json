{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/kallangerard/**"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "matchFileNames": ["manifests/shopping/**"],
      "matchManagers": ["kubernetes"],
      "enabled": false
    }
  ]
}
